# ---- Fiesta Platter environment variables ----
# Copy this file to `.env.local` and fill in real values.

# Public site URL (used for canonical URLs, sitemap, OpenGraph). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://fiestaplatter.com

# Resend API key for order email notifications (https://resend.com).
# If left blank, order submissions still succeed and fall back to Messenger confirmation.
RESEND_API_KEY=

# Inbox that receives new orders, and the verified "from" address for Resend.
ORDER_NOTIFICATION_EMAIL=orders@fiestaplatter.com
ORDER_FROM_EMAIL=Fiesta Platter <orders@fiestaplatter.com>

# Optional analytics (leave blank to disable).
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_FB_PIXEL_ID=

# Optional: Meta Conversions API (server-side Lead event, deduped against the
# client Pixel). Requires NEXT_PUBLIC_FB_PIXEL_ID above to also be set.
# Generate a token in Meta Events Manager > Settings > Conversions API.
META_CAPI_ACCESS_TOKEN=

# Google Sheets order log + admin dashboard (see docs/08-Google-Sheets-Setup.md).
# GOOGLE_SHEETS_WEBHOOK_URL is the Apps Script Web App URL; the secret must
# match the SHARED_SECRET constant pasted into that same Apps Script.
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=

# Admin dashboard login (/admin) — pick a strong password and a separate
# random secret (used only to sign the session cookie, never shown to you).
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
